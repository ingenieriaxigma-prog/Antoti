  "description": "Oti - Tu Asistente Financiero Personal con IA (Vite 5 Fixed)",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "clean": "node scripts/clear-vite-cache.js",
    "deep-clean": "node scripts/deep-clean-reinstall.js",
    "postinstall": "node scripts/verify-versions.js",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "verify": "node scripts/verify-setup.js"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "motion": "10.18.0",
    "lucide-react": "0.460.0",
    "recharts": "2.15.0",
    "sonner": "2.0.3",
    "react-hook-form": "7.55.0"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.2.1",
    "@testing-library/react": "14.0.0",
    "@testing-library/jest-dom": "6.1.0",
    "@testing-library/user-event": "14.5.0",
    "@vitest/ui": "1.3.1",
    "happy-dom": "12.10.0",
    "vitest": "1.3.1",
    "typescript": "5.3.3",
    "vite": "5.1.0",
    "tailwindcss": "4.0.0"
  },
  "overrides": {
    "vite": "5.1.0",
    "@vitejs/plugin-react": "4.2.1"
  },
  "resolutions": {
    "vite": "5.1.0",
    "@vitejs/plugin-react": "4.2.1"
  },
  "pnpm": {
    "overrides": {
      "vite": "5.1.0",
      "@vitejs/plugin-react": "4.2.1"
    }
  }
